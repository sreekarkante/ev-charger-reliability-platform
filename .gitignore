# Dependency directories (large files, easily re-installable)
node_modules/
backend/node_modules/
frontend/node_modules/

# Sensitive Configuration files (contains database credentials & JWT keys)
.env
backend/.env
frontend/.env
*.env

# Local Databases (if fallback engines were ever used)
*.db
*.db-journal
backend/prisma/dev.db

# Production distribution builds
dist/
build/
backend/dist/
frontend/dist/

# OS-specific files
.DS_Store
Thumbs.db

# Log records
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log
